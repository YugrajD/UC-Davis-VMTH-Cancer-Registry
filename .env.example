# Copy this file to .env and fill in your values
# cp .env.example .env
# NEVER commit .env to git — it contains secrets.

# ──────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────
# Supabase Dashboard → Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your database password and [PROJECT-REF]
# with your Supabase project reference (e.g. "abcdefghijklmnop").
# The async URL uses the +asyncpg driver (for the FastAPI backend).
# The sync URL uses plain postgresql (for seed/ingestion scripts).
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
# Allowed origins for the frontend. No changes needed for local development.
CORS_ORIGINS=["http://localhost:5173"]

# ──────────────────────────────────────────────
# SUPABASE AUTH (Backend)
# ──────────────────────────────────────────────
# JWT Secret — used to verify user tokens signed with HS256.
# Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
# Leave blank if your project uses ES256/JWKS. Newer Supabase projects only
# need SUPABASE_URL below so the backend can fetch public signing keys.
SUPABASE_JWT_SECRET=

# Supabase project URL — used for JWKS key fetching (ES256 tokens).
# Supabase Dashboard → Settings → API → Project URL
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://yourproject.supabase.co

# ──────────────────────────────────────────────
# ADMIN ACCOUNTS
# ──────────────────────────────────────────────
# Comma-separated list of email addresses that have admin privileges.
# Admin users can access the Review Queue and approve/reject uploads.
# These must match the email addresses used to sign up in Supabase Auth.
ADMIN_EMAILS=admin@example.com

# ──────────────────────────────────────────────
# SUPABASE AUTH (Frontend)
# ──────────────────────────────────────────────
# Project URL — same as SUPABASE_URL above.
# Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://yourproject.supabase.co

# Browser-safe public key used by the Supabase JS client for auth flows.
# Supabase Dashboard → Settings → API → Project API Keys → anon / public /
# publishable key.
VITE_SUPABASE_ANON_KEY=your-public-or-publishable-key

# ──────────────────────────────────────────────
# GCP BATCH (Optional — for production ML inference)
# ──────────────────────────────────────────────
# Set USE_GCP_BATCH=true to route PetBERT inference through GCP Batch
# instead of the local ml-worker container. See docs/GCP_BATCH_SETUP.md.
USE_GCP_BATCH=false
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET=your-gcs-bucket-name
GCP_BATCH_IMAGE_URI=us-central1-docker.pkg.dev/your-project/vmth/petbert-batch:latest
GCP_BATCH_MACHINE_TYPE=n1-standard-4
GCP_BATCH_POLL_INTERVAL=60
GCP_BATCH_TIMEOUT_HOURS=12
# Place your service account key at secrets/gcp-sa-key.json
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-sa-key.json
